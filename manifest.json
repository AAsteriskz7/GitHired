{
  "manifest_version": 3,
  "name": "GitHired",
  "version": "1.0",
  "description": "Tracks job applications on GitHub and Google job boards.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://github.com/*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}